# Public production endpoints (safe to commit)
USER_APP_URL=https://mommate-exe.vercel.app
ADMIN_APP_URL=https://admin-mommate.vercel.app
API_BASE_URL=

# Production test accounts only. Never commit populated credentials.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_CARER_EMAIL=
E2E_CARER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Generated E2E data only; use an E2E_ prefix in values created by tests.
E2E_TEST_PHONE=
E2E_TEST_ADDRESS=
E2E_PAYMENT_TEST_MODE=

# Production-safe defaults. Destructive flows require an explicit opt-in.
E2E_RUN_DESTRUCTIVE=false
E2E_CLEANUP=true
