NODE_ENV=development
DEMO_SEED_PASSWORD=replace-with-a-demo-only-password
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mommate
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
APP_PUBLIC_URL=http://localhost:5173
ADMIN_PUBLIC_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
ATTENDANCE_RADIUS_METERS=300
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
REFUND_PROVIDER=manual
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=MomMate <no-reply@mommate.vn>
FIREBASE_PROJECT_ID=
# Service-account credentials are optional for ID-token verification.
# Configure them only when backend Firebase Admin operations require them.
FIREBASE_USE_SERVICE_ACCOUNT=false
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the three Firebase values above:
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
MIN_AREA_CARERS=3
